# ─── Frontend .env.example ────────────────────────────────────────────────────
# Copy to .env and fill in real values.
#
#   cp .env.example .env
#
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API ──────────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
# Development: http://localhost:5000/api/v1
# Production: https://govservices.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1

# ─── App Identity ─────────────────────────────────────────────────────────────
VITE_APP_NAME=GovServices
VITE_APP_DESCRIPTION=Your centralized gateway to verified government services worldwide
VITE_APP_URL=http://localhost:5173

# ─── Google AdSense ───────────────────────────────────────────────────────────
# Find your Publisher ID in Google AdSense dashboard -> Account -> Settings
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ─── Google Analytics ─────────────────────────────────────────────────────────
# Measurement ID from Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ADSENSE=false

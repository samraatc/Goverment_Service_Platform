# ─── Backend .env.example ────────────────────────────────────────────────────
# Copy to .env and fill in real values.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Client URLs (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Development (no auth):
MONGODB_URI=mongodb://localhost:27017/govservices
# Production (with auth):
# MONGODB_URI=mongodb://govservices_user:STRONG_PASSWORD@localhost:27017/govservices

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate secure secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-64-char-random-hex-string-for-access-tokens
JWT_REFRESH_SECRET=change-me-to-64-char-random-hex-string-for-refresh-tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=change-me-to-random-cookie-signing-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@govservices.com
EMAIL_FROM_NAME=GovServices

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
# Used by the seeder script to create the initial super admin account.
SUPER_ADMIN_EMAIL=superadmin@govservices.com
SUPER_ADMIN_PASSWORD=ChangeMe_Strong_Password_123!
SUPER_ADMIN_NAME=Super Admin

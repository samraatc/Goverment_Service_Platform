# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in real values.
#
#   cp .env.example .env
#
# NEVER commit the real .env file to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── Client URLs (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (no auth):
MONGODB_URI=mongodb://localhost:27017/govservices
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/govservices?retryWrites=true&w=majority

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-64-char-random-hex-access-token-secret
JWT_REFRESH_SECRET=change-me-64-char-random-hex-refresh-token-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=change-me-random-cookie-signing-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@govservices.com
FROM_NAME=GovServices Platform

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
# Used by `npm run seed` to create/sync the initial super admin account.
SUPER_ADMIN_EMAIL=superadmin@govservices.com
SUPER_ADMIN_PASSWORD=ChangeMe_Strong_Password_123!
SUPER_ADMIN_NAME=Super Admin

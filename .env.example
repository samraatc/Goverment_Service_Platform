# ─── Root .env.example ────────────────────────────────────────────────────────
# Used by docker-compose.yml for MongoDB authentication.
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB root (admin) credentials — used by Docker Compose to initialize MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=ChangeMe_VeryStrong_RootPassword_123!

# MongoDB application user credentials — used by the application to connect
MONGO_APP_USER=govservices_user
MONGO_APP_PASSWORD=ChangeMe_VeryStrong_AppPassword_123!
